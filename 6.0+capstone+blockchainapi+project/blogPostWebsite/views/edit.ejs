<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
</head>
<body>
  <%- include('partials/header.ejs'); %>

  <% if(locals.submit2) { %>
  <div class="alert alert-success text-center"   role="alert">
    congratulations 👏 you have edited your post!
  </div>

  <% } else if (locals.delete1) { %>
      <div class="alert alert-success text-center"   role="alert">
        Your post has been deleted!
      </div>

  <%  } else {%>

  <div class = "text-center" >
      <form action="/posts/<%= post.id %>" method="POST">
   <div class= "form-group">
    <label for="exampleInputEmail1"> Edit the name of your post </label>
    <input type="text" name="title" class=" text-center form-control" id="exampleInputEmail1" aria-describedby="emailHelp" placeholder="<%= post.title %>">
   </div>
   <div class="form-group">
    <label for="exampleInputPassword1">Edit your post  </label>
    <input type="text" name="content" class=" text-center form-control" id="exampleInputPassword1" placeholder="<%= post.content %>">
   </div>
   <button type="submit" class="btn btn-primary">Submit</button>


  </div>

  <%}%>
</form>
</body>
</html>
