<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Bootstrap Table</title>

    <!-- ✅ Correct Bootstrap CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>

  <body>
  <%if(locals.symbol) { %>
    <table class="table table-success table-striped">
      <tr>
        <th>symbol</th>
        <th>price_24h</th>
        <th>volume_24h</th>
        <th>last_trade_price</th>
      </tr>
      <tr>
        <td><%=locals.symbol%></td>
        <td><%=locals.price_24h%></td>
        <td><%=locals.volume_24h%></td>
        <td><%=locals.last_trade_price%></td>
      </tr>
    </table>
  <% } else{ %>
    <pr><%=content%></pr>
  <% }%>

    <!-- ✅ Correct Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
